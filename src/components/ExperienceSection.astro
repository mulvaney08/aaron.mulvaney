---
import SectionHeading from "./SectionHeading.astro";
import { siteData } from "../data/site";

type Props = {
  experience: typeof siteData.experience;
};

const { experience } = Astro.props;
---

<section class="section" id="experience" aria-labelledby="experience-title">
  <div class="shell">
    <SectionHeading
      id="experience-title"
      eyebrow="Experience"
      title="Operational leadership and delivery impact across platform-critical roles."
      intro="Each role highlights scope, execution ownership, and measurable outcomes."
    />
    <div class="timeline">
      {experience.map((item) => (
        <article class="timeline-card card" data-reveal>
          <div class="timeline-meta">
            <p>{item.start} - {item.end}</p>
            <span>{item.location}</span>
          </div>
          <div class="timeline-body">
            <h3>{item.role}</h3>
            <p class="timeline-company">
              {item.companyHref ? (
                <a href={item.companyHref} target="_blank" rel="noreferrer">{item.company}</a>
              ) : (
                item.company
              )}
            </p>
            <p>{item.summary}</p>
            <ul class="detail-list">
              {item.highlights.map((highlight) => (
                <li>{highlight}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
