---
import SectionHeading from "./SectionHeading.astro";
import { siteData } from "../data/site";

type Props = {
  contact: typeof siteData.contact;
};

const { contact } = Astro.props;
const formatUrlLabel = (url: string) => url.replace(/^https?:\/\//, "").replace(/\/$/, "");
---

<section class="section" id="contact" aria-labelledby="contact-title">
  <div class="shell">
    <div class="contact-panel card" data-reveal>
      <SectionHeading
        id="contact-title"
        eyebrow="Contact"
        title="Open to Staff+ operations engineering and Agile delivery leadership opportunities."
        intro="For recruiter outreach, role discussions, or interview scheduling, email is the fastest way to reach me."
      />
      <div class="contact-actions">
        <a class="button" href={`mailto:${contact.email}`}>Email Me</a>
        <a class="button button-secondary" href={contact.resumeHref} download>{contact.resumeLabel}</a>
      </div>
      <ul class="contact-list">
        {contact.phone && (
          <li>
            <span>Phone</span>
            <a href={`tel:${contact.phone.replace(/\s+/g, "")}`}>{contact.phone}</a>
          </li>
        )}
        <li>
          <span>Email</span>
          <a href={`mailto:${contact.email}`}>{contact.email}</a>
        </li>
        <li>
          <span>LinkedIn</span>
          <a href={contact.linkedin} target="_blank" rel="noreferrer">{formatUrlLabel(contact.linkedin)}</a>
        </li>
        {contact.github && contact.github !== "#" && (
          <li>
            <span>GitHub</span>
            <a href={contact.github} target="_blank" rel="noreferrer">{formatUrlLabel(contact.github)}</a>
          </li>
        )}
      </ul>
    </div>
  </div>
</section>
