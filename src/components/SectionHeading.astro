---
type Props = {
  id?: string;
  eyebrow: string;
  title: string;
  intro?: string;
};

const { id, eyebrow, title, intro } = Astro.props;
---

<div class="section-heading" data-reveal>
  <p class="section-eyebrow">{eyebrow}</p>
  <h2 id={id}>{title}</h2>
  {intro && <p class="section-intro">{intro}</p>}
</div>
