---
const navItems = [
  { label: "About", href: "#about" },
  { label: "Experience", href: "#experience" },
  { label: "Skills", href: "#skills" },
  { label: "Impact", href: "#projects" },
  { label: "Education", href: "#education" },
  { label: "Contact", href: "#contact" }
];
---

<header class="site-header">
  <div class="shell nav-shell">
    <a class="brand-mark" href="#top" aria-label="Go to top">
      <span>AM</span>
    </a>
    <nav aria-label="Primary">
      <ul class="nav-list">
        {navItems.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>
    <button class="theme-toggle" type="button" data-theme-toggle aria-label="Toggle color mode" aria-pressed="false">
      <span data-theme-label>Light</span>
      <span aria-hidden="true" class="theme-toggle-dot"></span>
    </button>
  </div>
</header>
