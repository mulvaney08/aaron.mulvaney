---
import SectionHeading from "./SectionHeading.astro";
import { siteData } from "../data/site";

type Props = {
  projects: typeof siteData.projects;
};

const { projects } = Astro.props;
---

<section class="section" id="projects" aria-labelledby="projects-title">
  <div class="shell">
    <SectionHeading
      id="projects-title"
      eyebrow="Impact Highlights"
      title="Representative initiatives with clear operational and delivery outcomes."
      intro="Each highlight shows the challenge, execution approach, and practical business impact."
    />
    <div class="project-grid">
      {projects.map((project) => (
        <article class="project-card card" data-reveal>
          <div class="project-topline">
            <h3>{project.title}</h3>
            <p>{project.summary}</p>
          </div>
          <ul class="tag-list" aria-label={`${project.title} technology stack`}>
            {project.stack.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <p class="project-outcome">{project.outcome}</p>
          <div class="project-links">
            {project.href && (
              <a href={project.href} target={project.href.startsWith("#") ? undefined : "_blank"} rel={project.href.startsWith("#") ? undefined : "noreferrer"}>
                {project.href.startsWith("#") ? "View Experience Context" : "External Reference"}
              </a>
            )}
            {project.repo && (
              <a href={project.repo} target="_blank" rel="noreferrer">Source</a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
